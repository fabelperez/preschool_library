generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("admin") // "admin"
  createdAt    DateTime @default(now())
}

model Teacher {
  id                 String             @id @default(cuid())
  name               String
  email              String?
  createdAt          DateTime           @default(now())
  checkouts          Checkout[]
  bookSubmissions    BookSubmission[]
  resourceCheckouts  ResourceCheckout[]
}

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String?
  books         Book[]
  shelfSections ShelfSection[]
}

model Shelf {
  id             String         @id @default(cuid())
  name           String
  type           String         @default("book") // "book" or "resource"
  position       Int            @default(0)
  layoutX        Float          @default(0)
  layoutY        Float          @default(0)
  layoutWidth    Float          @default(25)
  layoutHeight   Float          @default(14)
  layoutRotation Float          @default(0)
  sections       ShelfSection[]
  bins           Bin[]
}

model ShelfSection {
  id         String   @id @default(cuid())
  label      String?
  shelfId    String
  categoryId String
  position   Int      @default(0)
  shelf      Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([shelfId, categoryId])
}

model Qualifier {
  id    String @id @default(cuid())
  name  String @unique
  books Book[]
}

model Book {
  id                 String            @id @default(cuid())
  isbn               String?           @unique
  title              String
  author             String
  coverImageUrl      String?
  totalCopies        Int               @default(1)
  categoryId         String?
  category           Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  qualifierId        String?
  qualifier          Qualifier?        @relation(fields: [qualifierId], references: [id], onDelete: SetNull)
  binId              String?
  bin                Bin?              @relation(fields: [binId], references: [id], onDelete: SetNull)
  resourceId         String?
  resource           Resource?         @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  resourceCategoryId String?
  resourceCategory   ResourceCategory? @relation(fields: [resourceCategoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  checkouts          Checkout[]
}

model ResourceCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  resources   Resource[]
  books       Book[]
  checkouts   Checkout[]
}

model Bin {
  id        String     @id @default(cuid())
  number    Int
  label     String?
  theme     String     @default("General")
  shelfId   String
  shelf     Shelf      @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  resources Resource[]
  books     Book[]

  @@unique([shelfId, number])
  @@index([shelfId])
}

model Resource {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  quantity           Int                @default(1)
  resourceCategoryId String
  resourceCategory   ResourceCategory   @relation(fields: [resourceCategoryId], references: [id])
  binId              String
  bin                Bin                @relation(fields: [binId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  checkouts          ResourceCheckout[]
  books              Book[]

  @@index([binId])
  @@index([resourceCategoryId])
}

model ResourceCheckout {
  id           String    @id @default(cuid())
  resourceId   String
  teacherId    String
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  resource     Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  teacher      Teacher   @relation(fields: [teacherId], references: [id])

  @@index([resourceId])
  @@index([teacherId])
}

model Checkout {
  id                 String            @id @default(cuid())
  type               String            @default("BOOK") // "BOOK" or "THEME"
  bookId             String?
  resourceCategoryId String?
  teacherId          String
  checkedOutAt       DateTime          @default(now())
  returnedAt         DateTime?
  book               Book?             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  resourceCategory   ResourceCategory? @relation(fields: [resourceCategoryId], references: [id], onDelete: Cascade)
  teacher            Teacher           @relation(fields: [teacherId], references: [id])

  @@index([bookId])
  @@index([teacherId])
  @@index([resourceCategoryId])
}

model BookSubmission {
  id            String   @id @default(cuid())
  isbn          String?
  title         String
  author        String
  coverImageUrl String?
  totalCopies   Int      @default(1)
  notes         String?
  status        String   @default("pending") // "pending", "approved", "rejected"
  rejectReason  String?
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([teacherId])
}

model RoomFixture {
  id             String @id @default(cuid())
  type           String @default("custom") // "door", "window", "rug", "custom"
  label          String
  emoji          String @default("📦")
  layoutX        Float  @default(10)
  layoutY        Float  @default(10)
  layoutWidth    Float  @default(15)
  layoutHeight   Float  @default(15)
  layoutRotation Float  @default(0)
  borderStyle    String @default("solid") // "solid", "dashed", "none"
  bgColor        String @default("bg-gray-100/50")
  position       Int    @default(0)
}
